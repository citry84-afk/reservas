# Base de datos (SQLite local en desarrollo, Turso en producción)
DATABASE_URL=file:./local.db
# DATABASE_AUTH_TOKEN=   # Solo necesario con Turso en producción

# Contraseña del panel de administración
ADMIN_PASSWORD=admin123

# URL pública de la app (dominio propio o Vercel)
# NEXT_PUBLIC_APP_URL=https://tudominio.com

# Emails (Resend — https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=ReservaYa <reservas@tudominio.com>

# Pagos (Stripe — https://stripe.com) — opcional
# STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Cron de recordatorios (Vercel lo genera automáticamente en producción)
# CRON_SECRET=xxxxxxxx

# WhatsApp via Twilio (opcional — https://twilio.com)
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_WHATSAPP_FROM=+14155238886
